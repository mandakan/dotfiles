#!/usr/bin/env bash
# Bootstrap a fresh macOS machine from this dotfiles repo.
# Safe to re-run: every step is idempotent.
#
# Flow:
#   1. Homebrew (if missing)
#   2. Oh My Zsh (if missing) + powerlevel10k + zsh plugins
#   3. Claude Code CLI (if missing)
#   4. Symlink shell + editor dotfiles into $HOME
#   5. Symlink ~/.claude config (settings, hooks, statusline)
#   6. brew bundle
#   7. Generate nano syntax-highlight include + sanity-check PATH
#   8. pre-commit install (hook envs built lazily on first commit)
#
# Idempotent — re-run anytime to reconcile drift.
# Existing non-symlink targets are backed up to ~/.dotfiles-backup/<ts>/.

set -euo pipefail

DOTFILES="$(cd "$(dirname "$0")" && pwd)"
BACKUP="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"

log()  { printf '\033[1;34m→\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; exit 1; }

# Symlink src → dst. If dst already points to src, do nothing. If dst exists
# and isn't a matching symlink, move it into the timestamped backup dir.
link() {
    local src=$1 dst=$2
    [[ -e $src || -L $src ]] || die "missing source: $src"

    if [[ -L $dst && "$(readlink "$dst")" == "$src" ]]; then
        log "ok    $dst"
        return
    fi
    if [[ -e $dst || -L $dst ]]; then
        mkdir -p "$BACKUP"
        mv "$dst" "$BACKUP/"
        warn "backed up $dst → $BACKUP/"
    fi
    mkdir -p "$(dirname "$dst")"
    ln -s "$src" "$dst"
    log "linked $dst → $src"
}

# ─── 1. Homebrew ─────────────────────────────────────────────────────────

if ! command -v brew >/dev/null 2>&1; then
    log "installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/opt/homebrew/bin/brew shellenv)"

# ─── 2. Oh My Zsh ────────────────────────────────────────────────────────

if [[ ! -d $HOME/.oh-my-zsh ]]; then
    log "installing Oh My Zsh"
    # RUNZSH=no prevents the installer from launching an interactive shell.
    # CHSH=no prevents it from changing the login shell (do that manually).
    RUNZSH=no CHSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"

clone_once() {
    local repo=$1 dest=$2
    if [[ -d $dest ]]; then
        log "ok    $dest"
    else
        log "clone $repo → $dest"
        git clone --depth=1 "$repo" "$dest"
    fi
}

clone_once https://github.com/romkatv/powerlevel10k.git          "$ZSH_CUSTOM/themes/powerlevel10k"
clone_once https://github.com/zsh-users/zsh-autosuggestions.git  "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
clone_once https://github.com/zsh-users/zsh-syntax-highlighting.git "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

# ─── 3. Claude Code CLI ──────────────────────────────────────────────────

if ! command -v claude >/dev/null 2>&1; then
    log "installing Claude Code CLI"
    curl -fsSL https://claude.ai/install.sh | bash
fi

# ─── 4. Symlink shell + editor dotfiles ──────────────────────────────────

link "$DOTFILES/.zshrc"    "$HOME/.zshrc"
link "$DOTFILES/.p10k.zsh" "$HOME/.p10k.zsh"
link "$DOTFILES/.nanorc"   "$HOME/.nanorc"
link "$DOTFILES/Brewfile"  "$HOME/Brewfile"

# ─── 5. Claude Code config ───────────────────────────────────────────────

link "$DOTFILES/claude/settings.json"  "$HOME/.claude/settings.json"
link "$DOTFILES/claude/CLAUDE.md"      "$HOME/.claude/CLAUDE.md"
link "$DOTFILES/claude/RTK.md"         "$HOME/.claude/RTK.md"
link "$DOTFILES/claude/statusline.sh"  "$HOME/.claude/statusline.sh"
link "$DOTFILES/claude/hooks/rtk-rewrite.sh" "$HOME/.claude/hooks/rtk-rewrite.sh"

# ─── 6. Brewfile install ─────────────────────────────────────────────────

log "running brew bundle (this may take a while)"
brew bundle --file="$DOTFILES/Brewfile"

# ─── 7. Nano syntax-highlight include (per-machine, brew path varies) ────
# `.nanorc` includes `~/.nano-syntax.nanorc`. Nano's include directive
# doesn't expand shell substitutions, so we write the actual path here.

if nano_cellar=$(brew --cellar nano 2>/dev/null) && [[ -n $nano_cellar ]]; then
    cat > "$HOME/.nano-syntax.nanorc" <<EOF
# Auto-generated by dotfiles/install. Do not edit — rerun install to refresh.
include "$nano_cellar/*/share/nano/*.nanorc"
EOF
    log "wrote $HOME/.nano-syntax.nanorc"
fi

# Sanity check: warn if `nano` on PATH isn't brew's nano.
if command -v nano >/dev/null 2>&1; then
    actual=$(command -v nano)
    if [[ $actual != "$(brew --prefix)"/* ]]; then
        warn "\`nano\` resolves to $actual, not brew's nano."
        warn "Start a fresh shell (\`exec zsh\`) — PATH probably just needs reload."
    fi
fi

# ─── 8. pre-commit hooks ─────────────────────────────────────────────────
# Only register the git hook — don't build hook environments yet. Eager env
# setup (--install-hooks) invokes `python`, which can fail when the current
# shell's $PATH still holds stale pyenv shims from a previous .zshrc. Hook
# envs build lazily on the first commit from a fresh shell, which sidesteps
# the issue entirely.

if command -v pre-commit >/dev/null 2>&1 && [[ -f $DOTFILES/.pre-commit-config.yaml ]]; then
    log "installing pre-commit git hook into $DOTFILES"
    (cd "$DOTFILES" && pre-commit install)
fi

log "done."
[[ -d $BACKUP ]] && warn "previous files were backed up to $BACKUP"
log "start a fresh shell (or \`exec zsh\`) to pick up the new environment."
