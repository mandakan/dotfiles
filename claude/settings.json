{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "wiki-skills@wiki-skills": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "wiki-skills": {
      "source": {
        "source": "github",
        "repo": "kfchou/wiki-skills"
      }
    }
  },
  "effortLevel": "high",
  "agentPushNotifEnabled": true,
  "permissions": {
    "additionalDirectories": ["~/.claude-tmp"],
    "allow": [
      "Read(~/.claude-tmp/**)",
      "Write(~/.claude-tmp/**)",
      "Edit(~/.claude-tmp/**)",
      "Bash(mkdir -p ~/.claude-tmp/*)",
      "Bash(ls ~/.claude-tmp/**)",
      "Bash(cat ~/.claude-tmp/**)",
      "Bash(rm ~/.claude-tmp/**)",
      "Bash(mv ~/.claude-tmp/** ~/.claude-tmp/**)",
      "Bash(cp ~/.claude-tmp/** ~/.claude-tmp/**)"
    ]
  }
}
