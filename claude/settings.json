{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "wiki-skills@wiki-skills": true
  },
  "extraKnownMarketplaces": {
    "wiki-skills": {
      "source": {
        "source": "github",
        "repo": "kfchou/wiki-skills"
      }
    }
  },
  "effortLevel": "high"
}
